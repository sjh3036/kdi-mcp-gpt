KDI_API_KEY=your-kdi-openapi-key

# Comma-separated KDI Open API category codes.
# KDI documents show A for basic research reports. Add/remove codes after
# confirming the categories enabled for your API key.
KDI_CATEGORY_CODES=A,B,C,D,E,F
KDI_VERIFY_SSL=true

PORT=8000

# --- Estimate advisor MCP server (estimate_advisor_server.py) ---
# law.go.kr Open API user ID (register at https://open.law.go.kr).
LAW_OC=your-law-go-kr-oc-id
LAW_VERIFY_SSL=true

# Port for estimate_advisor_server.py when run as a separate service.
# PORT=8001
